# CandidateBackend – all values from .env (no fallbacks)
NODE_ENV=development
PORT=8003

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
CANDIDATE_DB_NAME=candidates_db
DB_POOL_SIZE=10

# Auth
JWT_SECRET=your_jwt_secret

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:4000,http://localhost:4001,http://localhost:4002,http://localhost:4003,http://localhost:5173,http://127.0.0.1:4000,http://127.0.0.1:4001,http://127.0.0.1:4002,http://127.0.0.1:4003

# MongoDB – candidate interview responses (round 1–2), coding, aptitude
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=KareerGrowth

# Judge0 (RapidAPI) – for Practice run-code; get key from https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_RAPIDAPI_KEY=
